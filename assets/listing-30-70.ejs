<style>
  .quarto-listing-30-70 {
    margin: 0;
    padding: 0;
    font-size: 0.95rem;
  }

  .quarto-listing-30-70 .ql-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin: 1rem 0;
  }

  .quarto-listing-30-70 .ql-thumb {
    flex: 0 0 30%;
    max-width: 30%;
    align-self: center;
  }

  .quarto-listing-30-70 .ql-thumb img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    object-fit: cover;
  }

  .quarto-listing-30-70 .ql-body {
    flex: 1 1 70%;
    min-width: 0;
  }

  .quarto-listing-30-70 .ql-title {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--bs-body-color);
  }

  .quarto-listing-30-70 .ql-meta {
    margin: 0 0 0.5rem 0 !important;
    font-size: 0.85rem;
  }

  .quarto-listing-30-70 .ql-desc {
    margin: 0;
    font-size: 0.95rem;
    font-family: "Gill Sans", sans-serif !important;
    font-weight: 500 !important;
  }

  .quarto-listing-30-70 .ql-container-title {
    font-style: italic;
  }

  @media (max-width: 768px) {
    .quarto-listing-30-70 .ql-item {
      flex-direction: column;
    }
    .quarto-listing-30-70 .ql-thumb {
      flex: 0 0 auto;
      max-width: 100%;
    }
  }
</style>

<div class="quarto-listing-30-70">
  <%
    function authorText(author) {
      if (!author) return "";
      if (Array.isArray(author)) {
        return author
          .map((a) => (typeof a === "string" ? a : (a && a.name ? a.name : "")))
          .filter(Boolean)
          .join(", ");
      }
      if (typeof author === "object") return author.name ? String(author.name) : "";
      return String(author);
    }

    function asText(x) {
      if (x === null || x === undefined) return "";
      if (typeof x === "string") return x;
      if (typeof x === "number") return String(x);
      if (typeof x === "object") {
        // Quarto/CSL sometimes uses structured issued dates; fall back to JSON.
        try { return JSON.stringify(x); } catch { return ""; }
      }
      return String(x);
    }
  %>

  <% for (const item of items) { %>
    <%
      const img =
        (typeof item.image === "string" && item.image) ||
        (typeof item.thumbnail === "string" && item.thumbnail) ||
        (typeof item["listing-image"] === "string" && item["listing-image"]) ||
        "";
      const a = authorText(item.author);
      const containerTitle =
        (item.citation && typeof item.citation["container-title"] === "string" && item.citation["container-title"]) ||
        "";
      const issued = item.citation ? asText(item.citation.issued) : "";
    %>

    <div class="ql-item" <%= metadataAttrs(item) %>>
      <% if (img) { %>
        <div class="ql-thumb">
          <a href="<%- item.path %>" class="no-external">
            <img loading="lazy" src="<%- img %>" alt="">
          </a>
        </div>
      <% } %>

      <div class="ql-body">
        <h3 class="ql-title listing-title"><b>
          <%= item.title %>
        </b></h3>

        <% if (a || containerTitle || issued) { %>
          <p class="ql-meta listing-author">
            <% if (a) { %><%= a %><% } %><% if (containerTitle) { %><% if (a) { %>. <% } %><span class="ql-container-title"><%= containerTitle %></span><% } %><% if (issued) { %><% if (a || containerTitle) { %>. <% } %><%= issued %><% } %>
          </p>
        <% } %>

        <% if (item.description) { %>
          <div class="ql-desc listing-description">
            <%- item.description %>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
```
